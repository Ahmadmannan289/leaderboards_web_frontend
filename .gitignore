# --- frontend (Next.js) ---
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# --- backend (Python/Flask) ---
backend/venv/
backend/.venv/
backend/__pycache__/
backend/**/__pycache__/
backend/*.pyc

# --- env files (commit *.env.example, never the real ones) ---
.env
.env.local
.env.*.local
!*.env.example
!.env.example

# --- misc ---
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- vercel ---
.vercel

# --- claude code local settings (machine-specific permissions, not meant to be shared) ---
.claude/settings.local.json
